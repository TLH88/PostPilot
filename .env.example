# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Encryption key for user API keys (32 bytes, hex-encoded)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-encryption-key

# Resend (email)
# Get keys from https://resend.com/api-keys
# Use a "Sending access" scoped key, scoped to the mypostpilot.app domain.
# Recommended: separate keys for local dev and production.
#
# The client falls back to RESEND_PRODUCTION_API_KEY if RESEND_API_KEY is
# unset — Vercel uses the latter because env var keys can't be renamed in
# the UI. Local .env.local should use RESEND_API_KEY (canonical name).
RESEND_API_KEY=re_your_resend_api_key
