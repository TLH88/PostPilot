# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# dev-only auth bypass routes — by default, nothing under src/app/api/dev/
# ships to the repo. Exception: auto-login/route.ts is explicitly allowed
# because it's gated on VERCEL_ENV !== "production" plus two additional
# env-controlled checks (DEV_AUTO_LOGIN_TOKEN header + email allowlist).
# See that file's header comment for the full security contract.
#
# If you add a NEW file under src/app/api/dev/, it will be ignored by
# default — which is usually what you want for local-only tools. To make
# another dev file shippable, add a matching allow-rule below and review
# its security posture carefully before doing so.
src/app/api/dev/*
src/app/api/dev/**/*
!src/app/api/dev/auto-login/
!src/app/api/dev/auto-login/route.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
