# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# Playwright (BP-097)
/test-results/
/playwright-report/
/playwright/.cache/
# Per-tier storageState files — contain real Supabase session cookies
# for the E2E test users. Generated fresh by tests/e2e/global.setup.ts
# each run. Never commit.
tests/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# dev-only auth bypass routes — by default, nothing under src/app/api/dev/
# ships to the repo. If you add a shippable file here, add a matching
# allow-rule below and review its security posture carefully before doing so.
src/app/api/dev/*
src/app/api/dev/**/*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
